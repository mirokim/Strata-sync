{
  "name": "strata-sync",
  "private": true,
  "version": "0.3.0",
  "description": "AI Director Proxy System — Knowledge Graph UI",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5177 && cross-env VITE_DEV_SERVER_URL=http://localhost:5177 node electron/launch.cjs .\"",
    "electron:build": "npx vite build && npx electron-builder --config electron-builder.config.cjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-virtual": "^3.13.19",
    "@testing-library/dom": "^10.4.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "framer-motion": "^12.34.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.400.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.0.0",
    "three": "^0.175.0",
    "unified": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/d3-force": "^3.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.165.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.4"
  }
}
